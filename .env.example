# Zeitnest Umgebungsvariablen
# Diese Datei kopieren nach .env und Werte anpassen

# JWT Secret - UNBEDINGT ändern!
JWT_SECRET=hier-ein-langes-zufaelliges-secret-eintragen

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=zeitnest
DB_USER=zeitnest
DB_PASSWORD=hier-ein-sicheres-db-passwort

# Port (Standard: 3001)
PORT=3001

# Node Environment
NODE_ENV=production
